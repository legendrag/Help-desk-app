# Django Backend
DEBUG=1
SECRET_KEY=change-me-with-a-long-random-string
ALLOWED_HOSTS=*
CORS_ALLOW_ALL=1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database Engine: sqlite | mysql
DB_ENGINE=sqlite
DB_NAME=deskplus
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Initial super-admin (created automatically)
DEFAULT_SUPERADMIN_USERNAME=admin
DEFAULT_SUPERADMIN_EMAIL=admin@deskplus.local
DEFAULT_SUPERADMIN_PASSWORD=admin

# Frontend build-time variables
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_BASE_URL=ws://localhost:8000

# Backup settings (used by: python manage.py backup_db)
BACKUP_DIR=./backups
BACKUP_KEEP=7
