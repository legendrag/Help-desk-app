# Django Backend
DEBUG=1
SECRET_KEY=change-me-with-a-long-random-string
ALLOWED_HOSTS=*

# Database Engine: sqlite | mysql
DB_ENGINE=sqlite
DB_NAME=deskplus
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Initial super-admin (created automatically)
DEFAULT_SUPERADMIN_USERNAME=admin
DEFAULT_SUPERADMIN_EMAIL=admin@deskplus.local
DEFAULT_SUPERADMIN_PASSWORD=admin


# Backup settings (used by: python manage.py backup_db)
BACKUP_DIR=./backups
BACKUP_KEEP=7

# Web Push Settings (optional, generated dynamically if blank)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_ADMIN_EMAIL=admin@deskplus.local
